# AetherMux orchestrator configuration. Copy to .env and adjust.

# HTTP API port the orchestrator listens on.
PORT=8080

# PostgreSQL connection string for session state.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aethermux

# Shared API token for BOTH the HTTP API and the WebSocket (/ws). REQUIRED:
# auth is fail-closed and the orchestrator refuses to start without it. Every
# request except /healthz must present it.
AETHERMUX_API_TOKEN=change-me

# Host directory under which per-session sandbox workspaces are created.
# Must exist on the Docker host (see docker-compose.yml for why).
AETHERMUX_WORKSPACE_ROOT=/srv/aethermux/workspaces

# Base image used for sandbox containers.
AETHERMUX_SANDBOX_IMAGE=alpine:3.20

# Allowed CORS origin for the browser console (served from a separate origin).
# Default "*" (the token is the access control, not the origin); set to the
# console's origin to lock it down.
AETHERMUX_CORS_ORIGIN=*

# The Phase 2 console (docker-compose `console` service, http://localhost:5173)
# needs no env of its own — point it at the orchestrator + token via URL params:
#   http://localhost:5173/?api=http://localhost:8080&token=<AETHERMUX_API_TOKEN>
